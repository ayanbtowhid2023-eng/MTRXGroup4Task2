/**
 ******************************************************************************
 * @file    main.c
 * @brief   Exercise 3 - Serial Interface test
 *
 * Hardware setup:
 *   - USB cable from STM32F3 Discovery board to Mac (for screen output)
 *   - Jumper wire between PA2 (USART2 TX) and PA3 (USART2 RX) for loopback
 *
 * USART1 (PC10/PC11) is wired to the on-board ST-Link so its output appears
 * directly in screen on your Mac via the USB cable.
 *
 * USART2 (PA2/PA3) is used for structured packet testing via the loopback
 * jumper wire.
 *
 * To view output on Mac, open Terminal and run:
 *   screen /dev/tty.usbmodem103 115200
 *
 * How to verify each task:
 *
 *   7.3a - Raw bytes sent and received correctly if "Loopback test PASSED!"
 *          appears in screen.
 *
 *   7.3b - Debug strings visible in screen terminal on startup.
 *
 *   7.3c - Set a breakpoint at the start of sendMsg in serial.c and step
 *          through. Verify bytes are: [0xAA | size | type | body | chk | 0x55]
 *
 *   7.3d - "Loopback test PASSED!" with correct x/y/z/ts values in screen.
 *          Also set a breakpoint in on_rx_complete and inspect Variables panel.
 *
 *   7.3e - Set a breakpoint inside USART2_IRQHandler. Check the Call Stack
 *          panel to confirm it is called from the interrupt vector, not
 *          from the main loop.
 ******************************************************************************
 */

#include <stdint.h>
#include <stddef.h>
#include <string.h>
#include <stdio.h>
#include "serial.h"
#include "stm32f303xc.h"

/* =========================================================================
 * Message type identifiers
 * ====================================================================== */
#define MSG_TYPE_SENSOR  0x01
#define MSG_TYPE_COMMAND 0x02

/* =========================================================================
 * Example message structures
 * ====================================================================== */

/** Sensor data - sent as MSG_TYPE_SENSOR */
typedef struct {
    uint16_t x;
    uint16_t y;
    uint16_t z;
    uint32_t timestamp_ms;
} SensorData;

/** Command - sent as MSG_TYPE_COMMAND */
typedef struct {
    uint8_t command_id;
    uint8_t param;
} CommandMsg;

/* =========================================================================
 * Global state
 * ====================================================================== */
static volatile uint8_t  g_new_data_available   = 0;
static SensorData        g_last_sensor_data      = {0};
static volatile uint8_t  g_loopback_test_passed  = 0;
static volatile uint32_t g_packets_received      = 0;

static const SensorData TX_SENSOR_DATA = {
    .x            = 100,
    .y            = 200,
    .z            = 300,
    .timestamp_ms = 12345
};

/* =========================================================================
 * Callbacks
 * ====================================================================== */
void on_tx_complete(uint32_t bytes_sent)
{
    (void)bytes_sent;
}

void on_rx_complete(uint8_t *data, uint32_t num_bytes)
{
    /* Runs in interrupt context - keep short */
    g_packets_received++;
    if (num_bytes == sizeof(SensorData)) {
        memcpy(&g_last_sensor_data, data, sizeof(SensorData));
        g_new_data_available = 1;
    }
}

/* =========================================================================
 * IRQ Handlers
 * ====================================================================== */
void USART1_IRQHandler(void)
{
    SerialReceiveHandler(&USART1_PORT);
}

void USART2_IRQHandler(void)
{
    /* Breakpoint here confirms 7.3e: called from interrupt, not main loop */
    SerialReceiveHandler(&USART2_PORT);
}

/* =========================================================================
 * main
 * ====================================================================== */
int main(void)
{
    char debug_buf[64];

    /* USART1 (PC10/PC11) - debug output visible in screen terminal */
    SerialInitialise(BAUD_115200, &USART1_PORT, &on_tx_complete, NULL);

    /* USART2 (PA2/PA3) - structured packet loopback test */
    SerialInitialise(BAUD_115200, &USART2_PORT, NULL, &on_rx_complete);

    /* 7.3b: debug strings */
    SerialOutputString((uint8_t*)"================================\r\n", &USART1_PORT);
    SerialOutputString((uint8_t*)"MTRX2700 Exercise 3 - Serial Module\r\n", &USART1_PORT);
    SerialOutputString((uint8_t*)"USART1: debug output (PC10/PC11)\r\n", &USART1_PORT);
    SerialOutputString((uint8_t*)"USART2: loopback test (PA2->PA3)\r\n", &USART1_PORT);
    SerialOutputString((uint8_t*)"================================\r\n", &USART1_PORT);

    /* 7.3c + 7.3a: send structured packet over USART2 */
    SerialOutputString((uint8_t*)"Sending SensorData packet...\r\n", &USART1_PORT);
    sendMsg((void*)&TX_SENSOR_DATA, sizeof(TX_SENSOR_DATA),
            MSG_TYPE_SENSOR, &USART2_PORT);

    for (;;) {
        if (g_new_data_available) {
            g_new_data_available = 0;

            if (g_last_sensor_data.x            == TX_SENSOR_DATA.x &&
                g_last_sensor_data.y            == TX_SENSOR_DATA.y &&
                g_last_sensor_data.z            == TX_SENSOR_DATA.z &&
                g_last_sensor_data.timestamp_ms == TX_SENSOR_DATA.timestamp_ms)
            {
                g_loopback_test_passed = 1;
                SerialOutputString((uint8_t*)"Loopback test PASSED!\r\n", &USART1_PORT);

                sprintf(debug_buf, "  x=%d y=%d z=%d ts=%lu\r\n",
                        g_last_sensor_data.x,
                        g_last_sensor_data.y,
                        g_last_sensor_data.z,
                        g_last_sensor_data.timestamp_ms);
                SerialOutputString((uint8_t*)debug_buf, &USART1_PORT);
            } else {
                g_loopback_test_passed = 0;
                SerialOutputString((uint8_t*)"Loopback test FAILED - data mismatch!\r\n",
                                   &USART1_PORT);
            }
        }
    }
}
