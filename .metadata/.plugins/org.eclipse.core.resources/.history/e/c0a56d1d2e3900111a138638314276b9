/**
 ******************************************************************************
 * @file    main.c
 * @brief   Exercise 3 - Serial Interface test
 *
 * Hardware setup:
 *   - USB cable from STM32F3 Discovery board to Mac (for screen output)
 *   - Jumper wire between PA2 (USART2 TX) and PA3 (USART2 RX) for loopback
 *
 * USART1 (PC10/PC11) -> ST-Link -> screen terminal on Mac
 * USART2 (PA2/PA3)   -> loopback jumper wire
 *
 * To view output: screen /dev/tty.usbmodem103 115200
 ******************************************************************************
 */

#include <stdint.h>
#include <stddef.h>
#include <string.h>
#include <stdio.h>
#include "serial.h"
#include "stm32f303xc.h"

#define MSG_TYPE_SENSOR  0x01
#define MSG_TYPE_COMMAND 0x02

typedef struct {
    uint16_t x;
    uint16_t y;
    uint16_t z;
    uint32_t timestamp_ms;
} SensorData;

typedef struct {
    uint8_t command_id;
    uint8_t param;
} CommandMsg;

static volatile uint8_t  g_new_data_available  = 0;
static SensorData        g_last_sensor_data     = {0};
static volatile uint8_t  g_loopback_test_passed = 0;
static volatile uint32_t g_packets_received     = 0;

static const SensorData TX_SENSOR_DATA = {
    .x            = 100,
    .y            = 200,
    .z            = 300,
    .timestamp_ms = 12345
};

void on_tx_complete(uint32_t bytes_sent)
{
    (void)bytes_sent;
}

void on_rx_complete(uint8_t *data, uint32_t num_bytes)
{
    g_packets_received++;
    if (num_bytes == sizeof(SensorData)) {
        memcpy(&g_last_sensor_data, data, sizeof(SensorData));
        g_new_data_available = 1;
    }
}

void USART1_IRQHandler(void)
{
    SerialReceiveHandler(&USART1_PORT);
}

void USART2_IRQHandler(void)
{
    SerialReceiveHandler(&USART2_PORT);
}

int main(void)
{
    char debug_buf[64];

    /* Initialise USART1 for debug output */
    SerialInitialise(BAUD_115200, &USART1_PORT, &on_tx_complete, NULL);
    SerialOutputString((uint8_t*)"USART1 init OK\r\n", &USART1_PORT);

    /* Initialise USART2 for loopback test */
    SerialInitialise(BAUD_115200, &USART2_PORT, NULL, &on_rx_complete);
    SerialOutputString((uint8_t*)"USART2 init OK\r\n", &USART1_PORT);

    /* Debug strings */
    SerialOutputString((uint8_t*)"================================\r\n", &USART1_PORT);
    SerialOutputString((uint8_t*)"MTRX2700 Exercise 3\r\n", &USART1_PORT);
    SerialOutputString((uint8_t*)"USART1: PC10/PC11  USART2: PA2/PA3\r\n", &USART1_PORT);
    SerialOutputString((uint8_t*)"================================\r\n", &USART1_PORT);

    /* Small delay to let USART2 stabilise before sending */
    for (volatile uint32_t i = 0; i < 0x8ffff; i++) {}

    /* Send structured packet over USART2 - looped back via PA2->PA3 jumper */
    SerialOutputString((uint8_t*)"Sending SensorData packet...\r\n", &USART1_PORT);
    sendMsg((void*)&TX_SENSOR_DATA, sizeof(TX_SENSOR_DATA),
            MSG_TYPE_SENSOR, &USART2_PORT);
    SerialOutputString((uint8_t*)"sendMsg complete\r\n", &USART1_PORT);

    for (;;) {
        if (g_new_data_available) {
            g_new_data_available = 0;

            if (g_last_sensor_data.x            == TX_SENSOR_DATA.x &&
                g_last_sensor_data.y            == TX_SENSOR_DATA.y &&
                g_last_sensor_data.z            == TX_SENSOR_DATA.z &&
                g_last_sensor_data.timestamp_ms == TX_SENSOR_DATA.timestamp_ms)
            {
                g_loopback_test_passed = 1;
                SerialOutputString((uint8_t*)"Loopback test PASSED!\r\n", &USART1_PORT);

                sprintf(debug_buf, "  x=%d y=%d z=%d ts=%lu\r\n",
                        g_last_sensor_data.x,
                        g_last_sensor_data.y,
                        g_last_sensor_data.z,
                        g_last_sensor_data.timestamp_ms);
                SerialOutputString((uint8_t*)debug_buf, &USART1_PORT);
            } else {
                g_loopback_test_passed = 0;
                SerialOutputString((uint8_t*)"Loopback test FAILED!\r\n", &USART1_PORT);
            }
        }
    }
}
